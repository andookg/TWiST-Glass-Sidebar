OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-realtime-whisper
OPENAI_PERSONA_MODEL=gpt-4o
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_TRANSLATE_MODEL=gpt-realtime-translate
OPENAI_REALTIME_VOICE=marin

# Optional local browser key setup controls
BROWSER_KEY_SETUP_DISABLED=false
# RUNTIME_SECRETS_PATH=.data/runtime-secrets.json
AGENT_BRIEF_PUBLIC=false

# Optional local memory stash controls
MEMORY_STASH_UPLOAD_DISABLED=false

# Persona model routing: openai, anthropic, openrouter, or custom
PERSONA_PROVIDER=openai

# Anthropic Claude persona cards (Messages API + tool-use schema)
ANTHROPIC_API_KEY=
ANTHROPIC_PERSONA_MODEL=claude-sonnet-4-6

# OpenRouter persona cards
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_TITLE=TWiST Glass Sidebar
OPENROUTER_ALLOW_FALLBACKS=true
OPENROUTER_DATA_COLLECTION=deny
# OPENROUTER_PROVIDER_ORDER=openai,anthropic,google-vertex

# Any OpenAI-compatible chat-completions gateway, including local runners.
# Examples:
#   Ollama:    AI_GATEWAY_BASE_URL=http://127.0.0.1:11434/v1   AI_GATEWAY_MODEL=llama3.1
#   LM Studio: AI_GATEWAY_BASE_URL=http://127.0.0.1:1234/v1    AI_GATEWAY_MODEL=local-model
#   vLLM:      AI_GATEWAY_BASE_URL=http://127.0.0.1:8000/v1    AI_GATEWAY_MODEL=Qwen/Qwen2.5-7B-Instruct
AI_GATEWAY_BASE_URL=https://your-gateway.example.com
AI_GATEWAY_API_KEY=
AI_GATEWAY_MODEL=your/provider-model
# AI_GATEWAY_HEADERS={"X-Custom-Header":"value"}

# Secure storage adapters: none, local, webhook, supabase, or custom
DATA_STORAGE_PROVIDER=none

# Local JSONL storage, useful for local-first demos
DATA_STORAGE_LOCAL_PATH=.data/sidebar-events.jsonl
# DATA_STORAGE_ALLOW_ABSOLUTE_PATH=false

# Any webhook/cloud automation platform: Zapier, Make, n8n, Pipedream, etc.
DATA_STORAGE_WEBHOOK_URL=https://your-webhook.example.com/events
DATA_STORAGE_WEBHOOK_SECRET=

# Any custom cloud/software API that accepts JSON POST
DATA_STORAGE_CUSTOM_URL=https://your-api.example.com/events
DATA_STORAGE_CUSTOM_API_KEY=

# Supabase REST insert target
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=twist_sidebar_events
