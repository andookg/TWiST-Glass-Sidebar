{
  "name": "twist-glass-sidebar",
  "version": "0.1.0",
  "private": false,
  "description": "Open-source live podcast sidebar with OpenAI Realtime transcription, AI persona cards, project memory, and agent handoffs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andookg/TWiST-Glass-Sidebar.git"
  },
  "bugs": {
    "url": "https://github.com/andookg/TWiST-Glass-Sidebar/issues"
  },
  "homepage": "https://github.com/andookg/TWiST-Glass-Sidebar#readme",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "setup": "node scripts/setup-local.mjs",
    "activate": "node scripts/activate.mjs",
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "doctor": "node scripts/doctor.mjs",
    "verify": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3"
  }
}
