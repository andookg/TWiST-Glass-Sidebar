{
  "name": "twist-glass-sidebar",
  "version": "0.1.0",
  "private": false,
  "author": "Andres G",
  "description": "Open-source live podcast sidebar with OpenAI Realtime transcription, four AI persona cards, two-stream recording, project memory, and agent handoffs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andookg/TWiST-Glass-Sidebar.git"
  },
  "bugs": {
    "url": "https://github.com/andookg/TWiST-Glass-Sidebar/issues"
  },
  "homepage": "https://github.com/andookg/TWiST-Glass-Sidebar#readme",
  "main": "desktop/main.cjs",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "setup": "node scripts/setup-local.mjs",
    "activate": "node scripts/activate.mjs",
    "desktop": "electron desktop/main.cjs",
    "desktop:assets": "node scripts/create-desktop-assets.mjs",
    "desktop:pack": "npm run desktop:assets && npm run build && electron-builder --mac dmg dir",
    "dev": "next dev",
    "dev:local": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "doctor": "node scripts/doctor.mjs",
    "verify": "npm run typecheck && npm run build"
  },
  "dependencies": {
    "lucide-react": "^0.475.0",
    "next": "^15.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@types/node": "^22.10.10",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.34.5",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.twist.glasssidebar",
    "productName": "TWiST Glass Sidebar",
    "asar": true,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      ".next/**/*",
      "app/**/*",
      "desktop/**/*",
      "lib/**/*",
      "public/**/*",
      "next-env.d.ts",
      "next.config.*",
      "package.json",
      "tsconfig.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "dir"
      ],
      "hardenedRuntime": true,
      "entitlements": "desktop/entitlements.mac.plist",
      "entitlementsInherit": "desktop/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "TWiST Glass Sidebar listens to podcast or microphone audio for live transcription and AI sidebar cards.",
        "NSCameraUsageDescription": "TWiST Glass Sidebar can access camera/video sources if you choose to share them for capture.",
        "NSScreenCaptureUsageDescription": "TWiST Glass Sidebar captures a selected screen, window, or tab so it can transcribe podcast audio and record the enhanced stream."
      }
    },
    "dmg": {
      "title": "TWiST Glass Sidebar",
      "icon": "build/icon.icns",
      "background": "build/dmg-background.png",
      "iconSize": 96,
      "window": {
        "width": 660,
        "height": 420
      },
      "contents": [
        {
          "x": 164,
          "y": 214,
          "type": "file"
        },
        {
          "x": 496,
          "y": 214,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
